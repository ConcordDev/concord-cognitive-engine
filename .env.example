# Concord Cognitive Engine - Environment Configuration
# Copy this file to .env and fill in the REQUIRED values

# ============================================
# REQUIRED - Must set these for the app to work
# ============================================

# JWT secret for authentication (generate with: openssl rand -hex 64)
JWT_SECRET=

# Admin password (minimum 12 characters)
ADMIN_PASSWORD=

# OpenAI API key for LLM features (chat, forge, dream, etc.)
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ============================================
# DOMAIN CONFIGURATION
# ============================================

# Allowed origins for CORS
ALLOWED_ORIGINS=https://concord-os.org

# Public URLs (baked into frontend at build time)
NEXT_PUBLIC_API_URL=https://concord-os.org
NEXT_PUBLIC_SOCKET_URL=https://concord-os.org

# ============================================
# SERVER CONFIGURATION
# ============================================

# Backend port
PORT=5050

# Node environment
NODE_ENV=production

# Data directory for persistent storage
DATA_DIR=/data

# ============================================
# LLM CONFIGURATION (Optional)
# ============================================

# Ollama host (if using local Ollama)
# For Docker: http://ollama:11434
# For external: http://your-ollama-server:11434
OLLAMA_HOST=http://ollama:11434

# Default model for Ollama
OLLAMA_MODEL=llama3.2

# Enable LLM features
LLM_ENABLED=true

# ============================================
# FIVE-BRAIN COGNITIVE ARCHITECTURE (Optional)
# ============================================

# Concord runs five Ollama brains (4 cognitive + 1 vision). Each can have its
# own Ollama instance, URL, and model — all env-overridable. Defaults below
# come from server/lib/brain-config.js.
#
# Brain 1: Conscious — chat, deep reasoning, council deliberation (port 11434)
# BRAIN_CONSCIOUS_URL=http://ollama-conscious:11434
# BRAIN_CONSCIOUS_MODEL=concord-conscious:latest

# Brain 2: Subconscious — autogen, dream, evolution, synthesis (port 11435)
# BRAIN_SUBCONSCIOUS_URL=http://ollama-subconscious:11434
# BRAIN_SUBCONSCIOUS_MODEL=qwen2.5:7b-instruct-q4_K_M

# Brain 3: Utility — lens interactions, entity actions, quick tasks (port 11436)
# BRAIN_UTILITY_URL=http://ollama-utility:11434
# BRAIN_UTILITY_MODEL=qwen2.5:3b

# Brain 4: Repair — error detection, auto-fix, runtime repair (port 11437)
# BRAIN_REPAIR_URL=http://ollama-repair:11434
# BRAIN_REPAIR_MODEL=qwen2.5:0.5b

# Brain 5: Vision — LLaVA image understanding, food vision, doc layout (port 11438)
# BRAIN_VISION_URL=http://ollama-vision:11434
# BRAIN_VISION_MODEL=qwen2.5vl:7b

# ctx.llm.chat() routes to conscious and falls back to subconscious. There is
# no OpenAI emergency-fallback path. Per-user bring-your-own external API keys
# route per-brain-slot through the BYO key router (migration 170).
#
# For Docker deployment, the five ollama-* services are configured in
# docker-compose.yml.

# ============================================
# OPTIONAL: EXTERNAL SERVICES
# ============================================

# If using external APIs (optional, not required for local-only mode)
# ANTHROPIC_API_KEY=your-key-here
# OPENAI_API_KEY=your-key-here

# ============================================
# OAUTH PROVIDERS (Optional)
# ============================================

# Google OAuth (required if enabling Google sign-in)
# Create at: https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Connectors (Track C) — data-access OAuth (Calendar/Gmail/Slack) ──
# The connector-authorize flow (routes/connector-oauth.js) reuses GOOGLE_CLIENT_ID
# /GOOGLE_CLIENT_SECRET above. Register this redirect URI in the Google Cloud
# console (Authorized redirect URIs): <base>/api/oauth/google/authorize/callback
# CONNECTOR_OAUTH_REDIRECT_BASE pins the <base> when behind a proxy (else it is
# derived from the request host).
# CONNECTOR_OAUTH_REDIRECT_BASE=https://yourdomain.com
# Encrypts stored OAuth tokens at rest (AES-256-GCM). Falls back to JWT_SECRET /
# SESSION_SECRET if unset, but set a dedicated 32+ byte secret in production.
# CONCORD_CONNECTOR_TOKEN_KEY=change-me-32-bytes-min
# Slack fan-out (optional):
# SLACK_CLIENT_ID=your-slack-client-id
# SLACK_CLIENT_SECRET=your-slack-client-secret
# NOTE: Calendar/Gmail are sensitive/restricted Google scopes. The flow works for
# test users (<=100) immediately; a PUBLIC launch needs OAuth consent-screen
# verification + (Gmail restricted scope) an annual CASA assessment. See
# docs/CONNECTORS_GO_LIVE.md.

# Apple OAuth (required if enabling Apple sign-in)
# Create at: https://developer.apple.com/account/resources/identifiers
# APPLE_CLIENT_ID=your-apple-service-id
# APPLE_TEAM_ID=your-apple-team-id
# APPLE_KEY_ID=your-apple-key-id
# APPLE_PRIVATE_KEY=your-apple-private-key-contents

# ============================================
# EMAIL / SMTP (Required for password reset & notifications)
# ============================================

# SMTP server configuration
# Works with SendGrid, Postmark, Mailgun, SES, or any SMTP relay
# If not configured, emails are logged to console (dev mode only)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your-sendgrid-api-key
# SMTP_FROM=noreply@concord-os.org
# SMTP_FROM_NAME=Concord

# ============================================
# ERROR ALERTING (Recommended for production)
# ============================================

# Webhook URL for crash/error alerts (Slack, Discord, Teams, etc.)
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
# ALERT_WEBHOOK_TYPE=slack

# Sentry DSN for error tracking (optional, but recommended for production)
# SENTRY_DSN=https://xxx@sentry.io/yyy

# Sentry DSN for Next.js frontend (optional — same project as SENTRY_DSN is fine)
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/yyy

# ============================================
# CLOUD STORAGE / BACKUPS (Optional)
# ============================================

# AWS S3 bucket for offsite backups
# AWS_BUCKET=your-backup-bucket
# AWS_REGION=us-east-1

# Push notifications (optional)
# Generate VAPID keys with: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=your-vapid-public-key

# Encryption key for sensitive data at rest
# ENCRYPTION_KEY=your-encryption-key

# Directory for storing uploaded artifact files > 1MB (defaults to ./uploads/artifacts)
# Use an absolute path on the host or a mounted volume path in Docker
# ARTIFACTS_DIR=/data/artifacts

# ============================================
# SECURITY (CRITICAL - Must configure for production)
# ============================================

# NOTE: JWT_SECRET and ADMIN_PASSWORD are defined at the top of this file (lines 9, 12).
# Do NOT set them again here — duplicate definitions cause confusion.

# (JWT_SECRET and ADMIN_PASSWORD — see REQUIRED section at the top)

# Authentication mode.
#   public  — no login required. req.user populated opportunistically
#             from a Bearer token if present. Presence tracking, per-user
#             quotas, and attribution still work for logged-in users but
#             anonymous traffic is allowed. Use for local-first / single
#             tenant / trusted LAN deploys.
#   jwt     — JWT Bearer/cookie required for all non-public routes.
#             Recommended for internet-facing production.
#   apikey  — API key via X-API-Key header required.
#   hybrid  — accepts JWT cookies, JWT Bearers, OR API keys.
#             Use for production when serving both web clients and
#             programmatic integrations.
AUTH_MODE=hybrid

# Enable authentication (defaults to true in production)
AUTH_ENABLED=true

# Session secret (generate with: openssl rand -hex 32)
SESSION_SECRET=

# API key for protected endpoints (optional)
# API_KEY=your-api-key

# PostgreSQL SSL settings (for remote databases)
# POSTGRES_SSL=true
# POSTGRES_SSL_REJECT_UNAUTHORIZED=true  # Set to false only for self-signed certs

# ============================================
# PERFORMANCE
# ============================================

# Max DTUs in memory
MAX_DTUS_IN_MEMORY=10000

# Queue processing batch size
BATCH_SIZE=100

# ============================================
# MULTIMODAL / VISION (Optional)
# ============================================

# Vision analysis uses a local Ollama vision model (default qwen2.5vl:7b — Qwen2.5-VL, Apache-2.0)
# OLLAMA_VISION_MODEL=qwen2.5vl:7b

# Image generation uses local Stable Diffusion, or OpenAI DALL-E if OPENAI_API_KEY is set
# SD_URL=http://localhost:7860/sdapi/v1/txt2img
# COMFYUI_URL=http://localhost:8188/prompt
# A1111_URL=http://localhost:7860/sdapi/v1/txt2img

# ============================================
# VOICE / AUDIO (Optional)
# ============================================

# Speech-to-text uses whisper.cpp locally, or OpenAI Whisper if OPENAI_API_KEY is set
# WHISPER_CPP_BIN=/path/to/whisper

# Text-to-speech uses Piper locally, or OpenAI TTS if OPENAI_API_KEY is set
# PIPER_BIN=/path/to/piper
# PIPER_VOICE=en_US-lessac-medium

# ============================================
# WEB SEARCH (Optional)
# ============================================

# Web search uses DuckDuckGo HTML by default (no API key needed)
# For better results, run SearxNG locally:
# SEARXNG_URL=http://localhost:8080

# ============================================
# FEDERATION (Optional)
# ============================================

# Enable federation for multi-instance sync via Redis pub/sub
FEDERATION_ENABLED=false

# Redis connection for federation + cross-replica socket.io fanout.
# Required when running multiple server replicas (k8s HPA, multi-pod).
# docker-compose injects redis://redis:6379 automatically when the
# `redis` service is up; for bare-metal / RunPod, point at your own Redis.
# Leave blank for single-replica deployments — the server falls back to
# in-process socket.io rooms.
REDIS_URL=

# Federation channel name
# FEDERATION_CHANNEL=lattice_broadcast

# Unique node identifier for this instance
# NODE_ID=node-1

# ============================================
# ECONOMIC ENGINE / STRIPE
# ============================================

# Stripe API keys (from https://dashboard.stripe.com/apikeys)
# Use test keys for development, live keys for production
STRIPE_SECRET_KEY=sk_REPLACE_ME_NOT_A_REAL_KEY

# Stripe webhook secret (from Stripe dashboard webhooks section)
# Create webhook endpoint: https://yourdomain.com/api/economic/webhook
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME_NOT_A_REAL_SECRET

# Stripe Price IDs for subscriptions
# Create these products in Stripe dashboard:
# - Pro: $12/month recurring
# - Teams: $29/seat/month recurring
STRIPE_PRICE_PRO=price_REPLACE_ME_NOT_A_REAL_ID
STRIPE_PRICE_TEAMS=price_REPLACE_ME_NOT_A_REAL_ID

# Frontend URL for Stripe redirects
FRONTEND_URL=https://yourdomain.com

# Stripe Connect (for creator payouts)
# STRIPE_CONNECT_CLIENT_ID=ca_your_connect_client_id

# Economy tuning
# TOKENS_PER_USD=1
# MIN_WITHDRAW_TOKENS=20
# MAX_WITHDRAW_TOKENS_PER_DAY=5000

# Founder secret for emergency admin economy operations (optional).
# SECURITY: When set, allows bypassing normal approval flow for critical economy fixes
# (e.g., reversing erroneous transactions, emergency balance corrections).
# All operations gated by this secret are audit-logged with the caller's IP and timestamp.
# Generate with: openssl rand -hex 32
# WARNING: Treat this like a root password. Rotate after every use.
# FOUNDER_SECRET=

# ============================================
# MONITORING (Required for docker-compose)
# ============================================

# Grafana admin credentials (no defaults — must set explicitly)
GRAFANA_USER=admin
GRAFANA_PASSWORD=

# ============================================
# UNSAFE SURFACES (defaults to disabled)
# ============================================

# Terminal/sandbox command execution — disabled by default.
# Only enable for development or isolated/air-gapped deployments.
# ENABLE_TERMINAL_EXEC=false

# ============================================
# DEVELOPMENT ONLY
# ============================================

# Debug mode (never enable in production)
# DEBUG=true

# Disable authentication (never in production)
# DISABLE_AUTH=true

# ============================================================================
# PRODUCTION FEATURE FLAGS — 2026 go-live (ConKay builder · MCP · safety)
# ----------------------------------------------------------------------------
# Defaults are already prod-sensible. "ACTIVE BY DEFAULT" flags need no action.
# "NEEDS SECRET/INFRA" flags are OFF on purpose — turning them on without the
# dependency would fail; set them as you provision. Security flags must be set.
# ============================================================================

# ── Security (REQUIRED in production) ────────────────────────────────────────
# Token secret for the MCP OAuth authorization server. Falls back to JWT_SECRET
# if unset; set a dedicated 64-hex secret in prod. (openssl rand -hex 64)
# MCP_TOKEN_SECRET=
# SESSION_SECRET is already above and must be >=32 chars in prod.

# Public origin (used by the MCP Protected-Resource + Authorization-Server
# metadata, and OAuth issuer). Set to your real https origin.
# CONCORD_PUBLIC_URL=https://concord-os.org
# CONCORD_OAUTH_ISSUER=https://concord-os.org

# ── ACTIVE BY DEFAULT (prod-correct; shown for visibility) ───────────────────
# Content-safety gate (local checks) at the publish boundary. ON unless "0".
CONCORD_UGC_SAFETY=1
# HDC compositional recall in the Oracle (pure-compute, additive). ON unless "0".
CONCORD_HDC_RECALL=1
# MCP per-caller rate limit (calls/min).
CONCORD_MCP_RATE=60
# Code execution stays OFF in production by design (node:vm is not a hardened
# sandbox). Only enable behind a microVM/gVisor sandbox.
# CONCORD_CODE_EXEC_ENABLED=0

# ── NEEDS A SECRET — engages automatically once set ─────────────────────────
# External NSFW/abuse classifier for marketplace+ publish tiers. Free baseline
# is OpenAI omni-moderation (uses OPENAI_API_KEY or this dedicated key). Until a
# key is present, only the free local checks run.
# CONCORD_MODERATION_API_KEY=
# CONCORD_MODERATION_CLASSIFIER=on        # set "off" to force-disable

# CSAM hash-match provider (Thorn Safer Match / Cloudflare CSAM / PhotoDNA).
# REQUIRES an account + NCMEC ESP registration. Leave unset until provisioned.
# CONCORD_CSAM_PROVIDER=

# ── NEEDS INFRA — turn on when the dependency is deployed ────────────────────
# Qdrant ANN vector index. Leave unset to use the in-process cosine + keyword
# fallback. Set to "qdrant" only when a Qdrant container is reachable.
# VECTOR_DB=qdrant
# VECTOR_DB_HOST=qdrant
# QDRANT_PORT=6333
# QDRANT_API_KEY=
# QDRANT_COLLECTION=concord_embeddings

# Embedding model (nomic-embed-text @ 768 dims; auto-pulled by Ollama).
# EMBEDDING_MODEL=nomic-embed-text

# ── External connectors (set the OAuth app creds to go live) ────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# CONCORD_CONNECTOR_TOKEN_KEY=            # 64-hex; encrypts stored connector tokens
