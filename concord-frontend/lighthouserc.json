{
  "$comment": "Sprint 18 — Lighthouse CI config. Runs against built app at /lenses/<id> for the critical-path lenses. Asserts Core Web Vitals + accessibility + best-practices + SEO thresholds. Update the urls list as you grow critical-path coverage.",
  "ci": {
    "collect": {
      "url": [
        "http://localhost:3000/",
        "http://localhost:3000/lenses/chat",
        "http://localhost:3000/lenses/code",
        "http://localhost:3000/lenses/studio",
        "http://localhost:3000/lenses/music",
        "http://localhost:3000/lenses/marketplace",
        "http://localhost:3000/lenses/legal",
        "http://localhost:3000/lenses/creator",
        "http://localhost:3000/lenses/expert-mode",
        "http://localhost:3000/lenses/byo-keys",
        "http://localhost:3000/lenses/event-timeline",
        "http://localhost:3000/lenses/dtu",
        "http://localhost:3000/lenses/world",
        "http://localhost:3000/lenses/hub"
      ],
      "numberOfRuns": 3,
      "startServerCommand": "npm run start:ci",
      "startServerReadyPattern": "ready",
      "startServerReadyTimeout": 120000,
      "settings": {
        "preset": "desktop",
        "chromeFlags": "--no-sandbox --headless=new"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.60 }],
        "categories:accessibility": ["error", { "minScore": 0.90 }],
        "categories:best-practices": ["warn", { "minScore": 0.80 }],
        "categories:seo": ["warn", { "minScore": 0.80 }],
        "largest-contentful-paint": ["warn", { "maxNumericValue": 4000 }],
        "cumulative-layout-shift": ["warn", { "maxNumericValue": 0.25 }],
        "total-blocking-time": ["warn", { "maxNumericValue": 600 }],
        "interactive": ["warn", { "maxNumericValue": 6000 }],
        "color-contrast": "error",
        "image-alt": "error",
        "label": "error",
        "link-name": "error",
        "button-name": "error",
        "html-has-lang": "error",
        "meta-viewport": "error",
        "uses-https": "warn",
        "no-vulnerable-libraries": "error"
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": "./lighthouse-reports"
    }
  }
}
