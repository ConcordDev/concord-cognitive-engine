# NPM configuration for resilient builds
# Retry settings for transient network failures
fetch-retries=5
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000
fetch-timeout=300000

# Connection settings
maxsockets=10

# Registry configuration (use default npm registry)
registry=https://registry.npmjs.org/

# Disable update notifier during CI builds
update-notifier=false

# React 19 transition: several deps (lucide-react, @excalidraw/excalidraw's
# vendored @radix-ui tree, etc.) still publish peer-dep ranges that predate
# React 19, even though they run fine on it. Runtime compat is proven — the
# full 230-lens frontend renders on React 19.2. legacy-peer-deps lets
# `npm ci` install the locked tree instead of failing on stale peer
# metadata. Drop this once the lagging deps publish ^19 peer ranges.
legacy-peer-deps=true
