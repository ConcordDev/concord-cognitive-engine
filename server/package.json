{
  "name": "concord-server",
  "private": true,
  "version": "5.0.0",
  "type": "module",
  "scripts": {
    "start": "node --max-old-space-size=32768 server.js",
    "dev": "node --max-old-space-size=32768 --watch server.js",
    "test": "npm run test:main && npm run test:behavior",
    "test:main": "node --test --import=./tests/preload/no-egress.mjs --test-force-exit --test-timeout=300000 'tests/**/*.test.js' 'tests/**/*-tests.js'",
    "test:ci": "node scripts/ci-test-tolerant.mjs",
    "test:watch": "node --test --watch --test-timeout=60000 'tests/**/*.test.js' 'tests/**/*-tests.js'",
    "test:coverage": "node --test --import=./tests/preload/no-egress.mjs --test-force-exit --test-timeout=60000 --experimental-test-coverage 'tests/**/*.test.js' 'tests/**/*-tests.js'",
    "test:e2e": "node --test --test-force-exit --test-timeout=60000 'tests/e2e/**/*.test.js'",
    "test:behavior": "node --test --import=./tests/preload/no-egress.mjs --test-force-exit --test-timeout=900000 tests/behavior/lens-behavior-smoke.behavior.js",
    "test:sim": "node --test --test-force-exit --test-timeout=120000 'tests/sim/**/*.test.js'",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:ci": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "check-deps": "node scripts/check-emergent-deps.js",
    "check-route-auth": "node scripts/check-route-auth.js",
    "check-route-auth:update": "node scripts/check-route-auth.js --update",
    "migrate": "node migrate.js",
    "migrate:status": "node migrate.js --status",
    "smoke": "bash scripts/smoke.sh",
    "preflight": "bash ../scripts/preflight-production.sh",
    "backup": "bash scripts/backup.sh",
    "restore": "bash scripts/restore.sh",
    "cartograph": "node scripts/cartograph.js",
    "cartograph:static": "node scripts/cartograph.js --static",
    "cartograph:diff": "node scripts/cartograph.js --static --diff",
    "cartograph:graph": "node scripts/cartograph.js --static && (which dot >/dev/null 2>&1 && dot -Tsvg ../audit/cartograph/systems-graph.dot -o ../audit/cartograph/systems-graph.svg && echo 'systems-graph.svg rendered' || echo 'graphviz dot not on PATH; .dot source committed')",
    "detectors": "node scripts/run-detectors.js",
    "detectors:report": "node scripts/run-detectors.js --out ../audit/detectors/REPORT.md",
    "detectors:json": "node scripts/run-detectors.js --json",
    "detectors:diff": "node scripts/run-detectors.js --diff",
    "detectors:ci": "node scripts/run-detectors.js --ci",
    "detectors:baseline": "node scripts/run-detectors.js --rewrite-baseline",
    "detectors:history": "node scripts/run-detectors.js --append-history",
    "detectors:autofix": "node scripts/repair-cortex-apply.js --apply-all-low-risk",
    "repair-cortex:scan": "node scripts/repair-cortex-scan.js",
    "repair-cortex:apply": "node scripts/repair-cortex-apply.js",
    "cartograph:reason": "node scripts/cartograph-reason.js",
    "cartograph:reason:stress": "node scripts/cartograph-reason.js --stress-only",
    "cartograph:reason:diff": "node scripts/cartograph-reason.js --diff"
  },
  "lint-staged": {
    "*.{js,mjs,cjs}": [
      "eslint --fix --max-warnings=0"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@sentry/node": "^10.50.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.10.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "expo-server-sdk": "^3.10.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "helmet": "^7.1.0",
    "http-signature": "^1.4.0",
    "jsmidgen": "^0.1.8",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^9.0.1",
    "pdfkit": "^0.17.2",
    "playwright": "^1.59.1",
    "prom-client": "^15.1.0",
    "socket.io": "^4.7.4",
    "stripe": "^17.4.0",
    "uuid": "^9.0.1",
    "web-push": "^3.6.7",
    "ws": "^8.14.2",
    "y-websocket": "^3.0.0",
    "yaml": "^2.8.2",
    "yjs": "^13.6.30",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "typescript": "^5.9.3"
  },
  "optionalDependencies": {
    "@xenova/transformers": "^2.15.0",
    "meilisearch": "^0.37.0",
    "pg": "^8.11.3",
    "redis": "^4.6.12"
  },
  "overrides": {
    "protobufjs": "^7.5.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
