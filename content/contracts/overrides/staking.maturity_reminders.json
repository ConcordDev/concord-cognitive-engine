{
  "macro_id": "staking.maturity_reminders",
  "domain": "staking",
  "name": "maturity_reminders",
  "inputs": {
    "windowDays": { "type": "number", "min": 1, "max": 365 }
  },
  "invariants": [
    "typeof output === 'object' && output !== null",
    "typeof output.ok === 'boolean'",
    "output.ok === false || (Array.isArray(output.result.matured) && output.result.maturedCount === output.result.matured.length)",
    "output.ok === false || (Array.isArray(output.result.upcoming) && output.result.upcomingCount === output.result.upcoming.length)",
    "output.ok === false || (typeof output.result.windowDays === 'number' && output.result.windowDays >= 1)"
  ],
  "fuzz_cases": [
    { "input": {}, "expect": { "ok": true } },
    { "input": { "windowDays": 60 }, "expect": { "ok": true } }
  ],
  "_note": "maturity_reminders is a user-scoped READ. Internal owner actor → {} returns ok:true with empty matured/upcoming for a fresh user; never no_actor / no_db. windowDays is internally clamped [1,365] so the count arrays always agree with their *Count fields."
}
