{
  "macro_id": "sandbox.deleteReplay",
  "domain": "sandbox",
  "name": "deleteReplay",
  "inputs": { "replayId": { "type": "string", "maxLength": 80 } },
  "invariants": [
    "typeof output === 'object' && output !== null",
    "typeof output.ok === 'boolean'",
    "output.ok === false || (output.result && typeof output.result.count === 'number' && output.result.count >= 0)"
  ],
  "fuzz_cases": [
    { "input": {}, "expect": { "ok": false, "error": "replay_not_found" } },
    { "input": { "replayId": "nope" }, "expect": { "ok": false, "error": "replay_not_found" } }
  ],
  "_note": "Removes one of the caller's saved replays by id from per-user STATE. A missing/unknown id fails-closed with 'replay_not_found' (NEVER no_db). The assassin's internal owner actor has none → replay_not_found."
}
