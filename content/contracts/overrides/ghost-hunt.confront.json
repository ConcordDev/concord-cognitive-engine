{
  "macro_id": "ghost-hunt.confront",
  "domain": "ghost-hunt",
  "name": "confront",
  "inputs": {
    "residueId": { "type": "string", "maxLength": 96 },
    "worldId": { "type": "string", "maxLength": 64 }
  },
  "invariants": [
    "typeof output === 'object' && output !== null",
    "typeof output.ok === 'boolean'",
    "output.ok === true || typeof output.reason === 'string'",
    "output.ok === false || (output.result === 'win' || output.result === 'loss')",
    "output.ok === false || (typeof output.winChance === 'number' && output.winChance >= 0 && output.winChance <= 1)"
  ],
  "fuzz_cases": [
    { "input": {}, "expect": { "ok": false, "reason": "missing_residue_id" } },
    { "input": { "residueId": "nonexistent_residue" }, "expect": { "ok": false, "reason": "residue_not_found" } }
  ]
}
