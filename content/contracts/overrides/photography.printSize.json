{
  "macro_id": "photography.printSize",
  "domain": "photography",
  "name": "printSize",
  "inputs": {
    "widthPixels": { "type": "number", "required": false },
    "heightPixels": { "type": "number", "required": false },
    "dpi": { "type": "number", "required": false }
  },
  "invariants": [
    "typeof output === 'object' && output !== null",
    "typeof output.ok === 'boolean'",
    "output.ok === false || typeof output.result.resolution === 'string'",
    "output.ok === false || Number.isFinite(output.result.megapixels)",
    "output.ok === false || typeof output.result.maxPrintAt300DPI === 'string'",
    "output.ok === false || typeof output.result.maxPrintAt150DPI === 'string'",
    "output.ok === false || ['professional','good','web-only'].includes(output.result.quality)"
  ],
  "fuzz_cases": [
    { "input": { "artifact": { "data": {} } }, "expect": { "ok": true } },
    { "input": { "artifact": { "data": { "widthPixels": 4000, "heightPixels": 3000, "dpi": 300 } } }, "expect": { "ok": true } },
    { "input": { "artifact": { "data": { "widthPixels": 1024, "heightPixels": 768, "dpi": 150 } } }, "expect": { "ok": true } },
    { "input": { "artifact": { "data": { "widthPixels": "Infinity", "heightPixels": "1e999", "dpi": "NaN" } } }, "expect": { "ok": true } }
  ],
  "_note": "LENS_ACTIONS handler. NOT assassin-driven (LENS_ACTIONS only). Authored contract pinned by server/tests/photography-lens-macros.test.js. PhotographyActionPanel sends { artifact: { data: { widthPixels, heightPixels, dpi } } } (peeled → handler reads artifact.data.widthPixels/heightPixels/dpi). POISON: each value via parseInt|fallback (4000/3000/300) so 'Infinity'/'1e999'/'NaN' collapse to defaults; megapixels stays FINITE (never NaN/Infinity)."
}
