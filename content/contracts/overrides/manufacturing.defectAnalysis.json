{
  "macro_id": "manufacturing.defectAnalysis",
  "domain": "manufacturing",
  "name": "defectAnalysis",
  "reads_artifact_data": true,
  "inputs": {
    "defects": { "type": "array", "maxLength": 100000 },
    "inspected": { "type": "number" }
  },
  "invariants": [
    "typeof output === 'object' && output !== null",
    "output.ok === true",
    "Number.isInteger(output.result.defectCount) && output.result.defectCount >= 0",
    "Number.isFinite(output.result.defectRatePct) && output.result.defectRatePct >= 0",
    "typeof output.result.byType === 'object' && output.result.byType !== null",
    "['none','low','elevated','high'].includes(output.result.riskLevel)"
  ],
  "fuzz_cases": [
    { "input": { "artifact": { "data": { "inspected": 200, "defects": [{ "type": "scratch", "severity": "minor" }, { "type": "crack", "severity": "critical" }] } } }, "expect": { "ok": true } },
    { "input": { "artifact": { "data": { "inspected": 50, "defects": [] } } }, "expect": { "ok": true } },
    { "input": { "artifact": { "data": { "inspected": "bad", "defects": [{ "type": "x" }] } } }, "expect": { "ok": true } }
  ],
  "_note": "page.tsx handleAction('defectAnalysis') runs against a saved artifact; handler reads artifact.data.defects + inspected. Renders defectCount/inspected/defectRatePct/byType/bySeverity/topDefect/riskLevel. Rate = defects/inspected×100; inspected coerces to total on garbage so the rate is always finite. critical>0 → high risk."
}
