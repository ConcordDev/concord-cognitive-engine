{
  "macro_id": "services.commissionCalc",
  "domain": "services",
  "name": "commissionCalc",
  "reads_artifact_data": true,
  "inputs": {
    "sales": { "type": "array", "required": false },
    "tiers": { "type": "array", "required": false }
  },
  "invariants": [
    "typeof output === 'object' && output !== null",
    "typeof output.ok === 'boolean'",
    "output.ok === false || Number.isFinite(output.result.totalSales)",
    "output.ok === false || Number.isFinite(output.result.totalCommission)",
    "output.ok === false || Number.isFinite(output.result.effectiveRate)",
    "output.ok === false || Array.isArray(output.result.lineItems)",
    "output.ok === false || Array.isArray(output.result.bySalesperson)",
    "output.ok === false || output.result.lineItems.every(function(l){return Number.isFinite(l.amount) && Number.isFinite(l.commission);})",
    "output.ok === true || typeof (output.error || output.message) === 'string'"
  ],
  "fuzz_cases": [
    { "input": { "artifact": { "data": { "sales": [{ "salesperson": "Ray", "amount": 10000 }] } } }, "expect": { "ok": true } },
    { "input": { "artifact": { "data": { "sales": [] } } }, "expect": { "ok": true } },
    { "input": {}, "expect": { "ok": true } },
    { "input": { "artifact": { "data": { "sales": [{ "salesperson": "Ray", "amount": "1e999" }] } } }, "expect": { "ok": true } }
  ],
  "_note": "LENS_ACTIONS handler (path-3; NOT assassin-enumerated). Reads artifact.data.sales + params.tiers (default 3-tier 5/8/12%). RETURNS {totalSales,totalCommission,effectiveRate,lineItems:[{line,salesperson,description,amount,commission,effectiveRate}],bySalesperson:[{salesperson,totalSales,totalCommission}],tiers}. Tiered marginal commission. POISON: amount via parseFloat||0 — a non-finite '1e999' parses to Infinity so the contract asserts finiteness as a guard. try/catch wrapped. Pinned by server/tests/services-lens-macros.test.js."
}
