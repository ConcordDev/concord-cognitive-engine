{
  "macro_id": "landscaping.seasonalPlan",
  "domain": "landscaping",
  "name": "seasonalPlan",
  "inputs": {
    "hardnessZone": {
      "type": "number"
    }
  },
  "reads_artifact_data": true,
  "invariants": [
    "typeof output === 'object' && output !== null",
    "typeof output.ok === 'boolean'",
    "output.ok === false || Number.isFinite(output.result.zone)",
    "output.ok === false || (typeof output.result.plan === 'object' && output.result.plan !== null)",
    "output.ok === false || ['spring','summer','fall','winter'].every(s => Array.isArray(output.result.plan[s]) && output.result.plan[s].length > 0)",
    "output.ok === false || typeof output.result.currentSeason === 'string'",
    "output.ok === false || Array.isArray(output.result.immediateActions)",
    "output.ok === false || JSON.stringify(output.result.immediateActions) === JSON.stringify(output.result.plan[output.result.currentSeason])"
  ],
  "fuzz_cases": [
    {
      "input": {
        "artifact": {
          "data": {
            "hardnessZone": 6
          }
        }
      },
      "expect": {
        "ok": true
      }
    },
    {
      "input": {
        "artifact": {
          "data": {
            "hardnessZone": 9
          }
        }
      },
      "expect": {
        "ok": true
      }
    },
    {
      "input": {
        "artifact": {
          "data": {}
        }
      },
      "expect": {
        "ok": true
      }
    },
    {
      "input": {
        "artifact": {
          "data": {
            "hardnessZone": "Infinity"
          }
        }
      },
      "expect": {
        "ok": false
      }
    }
  ],
  "_note": "Pure compute, reads artifact.data. zone = parseInt(hardnessZone)||7. plan = {spring,summer,fall,winter} each an action-list array; currentSeason derived from the live month index; immediateActions === plan[currentSeason] (the column SeasonalPlanCalendar highlights as 'now'). NaN/Infinity zone → 7 default — never NaN. SeasonalPlanCalendar maps Object.entries(plan) and renders zone/currentSeason/immediateActions EXACTLY."
}
