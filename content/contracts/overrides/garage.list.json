{
  "macro_id": "garage.list",
  "domain": "garage",
  "name": "list",
  "inputs": {
    "worldId": { "type": "string", "maxLength": 64 },
    "kind": { "type": "string", "maxLength": 32 }
  },
  "invariants": [
    "typeof output === 'object' && output !== null",
    "typeof output.ok === 'boolean'",
    "output.ok === false || Array.isArray(output.vehicles)",
    "output.ok === false || output.vehicles.every(v => typeof v.id === 'string' && v.id.length > 0)",
    "output.ok === false || output.vehicles.every(v => ['cart','boat','canal_taxi'].includes(v.kind))",
    "output.ok === false || output.vehicles.every(v => typeof v.capacity === 'number' && v.capacity >= 1 && v.capacity <= 12)"
  ],
  "fuzz_cases": [
    { "input": { "worldId": "concordia-hub" }, "expect": { "ok": true } }
  ]
}
