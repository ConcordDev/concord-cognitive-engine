{
  "macro_id": "auctions.buy_orders",
  "domain": "auctions",
  "name": "buy_orders",
  "inputs": {
    "worldId": { "type": "string", "maxLength": 64 },
    "itemDescriptor": { "type": "string", "maxLength": 200 },
    "limit": { "type": "number", "min": 1, "max": 500 }
  },
  "invariants": [
    "typeof output === 'object' && output !== null",
    "typeof output.ok === 'boolean'",
    "output.ok === false || Array.isArray(output.buyOrders)",
    "output.ok === false || output.buyOrders.every(o => typeof o.unit_price_cc === 'number' && o.unit_price_cc > 0)",
    "output.ok === false || output.buyOrders.every(o => o.quantity_filled <= o.quantity_wanted)"
  ],
  "fuzz_cases": [
    { "input": { "limit": 20 }, "expect": { "ok": true } }
  ]
}
