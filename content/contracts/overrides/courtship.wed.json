{
  "macro_id": "courtship.wed",
  "domain": "courtship",
  "name": "wed",
  "inputs": {
    "partnerKind": { "type": "string", "enum": ["player", "npc"] },
    "partnerId": { "type": "string", "required": true, "maxLength": 80 }
  },
  "invariants": [
    "typeof output === 'object' && output !== null",
    "typeof output.ok === 'boolean'",
    "output.ok === true || typeof output.reason === 'string'",
    "output.reason !== 'affinity_too_low' || (typeof output.required === 'number' && output.required > 0 && output.required <= 1)",
    "output.ok === false || output.status === 'married'",
    "output.ok === false || typeof output.marriageId === 'string'"
  ],
  "fuzz_cases": [
    { "input": {}, "expect": { "ok": false } },
    { "input": { "partnerKind": "npc", "partnerId": "no_such_courtship" }, "expect": { "ok": false, "reason": "no_courtship" } }
  ]
}
