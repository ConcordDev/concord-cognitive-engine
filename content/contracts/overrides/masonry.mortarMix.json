  "fuzz_cases": [
    { "input": { "artifact": { "data": { "application": "structural" } } }, "expect": { "ok": true } },
    { "input": { "artifact": { "data": { "application": "repoint" } } }, "expect": { "ok": true } },
    { "input": { "artifact": { "data": {} } }, "expect": { "ok": true } },
    { "input": { "artifact": { "data": { "application": "not-a-real-mode" } } }, "expect": { "ok": true } }
