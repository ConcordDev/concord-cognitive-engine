{
  "macro_id": "sandbox.listDummyConfigs",
  "domain": "sandbox",
  "name": "listDummyConfigs",
  "inputs": {},
  "invariants": [
    "typeof output === 'object' && output !== null",
    "typeof output.ok === 'boolean'",
    "output.ok === false || (output.result && Array.isArray(output.result.dummyConfigs))",
    "output.ok === false || (typeof output.result.count === 'number' && output.result.count === output.result.dummyConfigs.length)"
  ],
  "fuzz_cases": [
    { "input": {}, "expect": { "ok": true } }
  ],
  "_note": "Reads the caller's saved dummy configs (newest first) from per-user STATE. The assassin's internal owner actor has none → ok:true with an empty array and count 0 (NEVER no_db)."
}
