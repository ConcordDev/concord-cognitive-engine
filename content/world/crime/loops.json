{
  "$schema": "world-flavor.v1",
  "description": "Urban noir — dense NPC routines, no seasons (always overcast), no creature flock (urban only), high scheme + economic activity.",
  "loops": {
    "npc-routine-cycle": { "enabled": true, "frequency": 3 },
    "signal-propagation-cycle": { "enabled": true, "frequency": 3 },
    "creature-flock-cycle": { "enabled": false },
    "environment-sensor": { "enabled": true, "frequency": 5 },
    "season-cycle": { "enabled": false },
    "npc-economy-cycle": { "enabled": true, "frequency": 6 },
    "land-claims-cycle": { "enabled": true, "frequency": 240 },
    "kingdom-decree-cycle": { "enabled": false },
    "npc-perception-snapshot": { "enabled": true, "frequency": 6 },
    "procgen-settlement-cycle": { "enabled": false },
    "procedural-npc-spawner": { "enabled": true, "frequency": 240 },
    "npc-conversation-initiator": { "enabled": true, "frequency": 6 },
    "npc-scheme-cycle": { "enabled": true, "frequency": 12 },
    "war-skirmish-cycle": { "enabled": true, "frequency": 6 },
    "world-population-cycle": { "enabled": true, "frequency": 60 }
  },
  "climate": {
    "baseTemp": 12,
    "humidity": 65,
    "airQuality": 70,
    "illumination": 0.7,
    "structuralStress": 0,
    "ambientDb": 60,
    "weather": "urban-overcast"
  },
  "factionStartState": {
    "default": { "stance": "expand", "momentum": 0.2 }
  },
  "skillCeilings": {
    "physical": 250, "fire": 80, "ice": 60, "water": 80,
    "lightning": 100, "bio": 60, "energy": 100, "poison": 200
  },
  "npcDensity": {
    "targetPerFaction": 120,
    "max": 900,
    "archetypeWeights": { "warrior": 1.0, "scholar": 0.7, "trader": 1.5, "mystic": 0.4, "guard": 1.3, "healer": 0.8, "hunter": 0.6 }
  },
  "marketplaceModulators": { "feeMultiplier": 1.05, "scarcityBias": 0.3 },
  "worldVoice": {
    "tone": "noir, terse, world-weary, 1940s-period slang",
    "vocabulary": ["wise guy", "racket", "dame", "shamus", "heater", "grift", "on the level", "in the know"],
    "avoid": ["modern slang", "tech jargon", "magical terms", "cheerful greetings"],
    "examples": [
      "You ask a lot of questions for somebody who looks like trouble.",
      "Word on the street says the boss ain't happy. You wanna make it three?"
    ]
  }
}
