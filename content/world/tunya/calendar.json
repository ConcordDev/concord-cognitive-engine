  "festival_lore_hooks": {
    "amity_courtship_ball_akeia": "Akeia's most consequential diplomatic event. Treaties drafted, marriages arranged, alliances tested. Foreign delegations attend at risk.",
    "arbor_silent_walk_nil": "Once a year Nil opens a single path through the outer grove. Walkers may walk it. None have ever asked to enter the inner grove. None have ever been refused, either, because none have asked.",
    "harvest_high_feast_aekon": "Aekon's twelve districts each contribute one dish. The twelfth district's dish has been the same recipe for four generations. No one outside the district will say what it is.",
    "cull_sangree_challenges": "Sangree clan warriors may formally challenge the warlord during Cull. Iyatte has accepted three challenges in her tenure. She has won three. The fourth Cull is approaching."
  }
