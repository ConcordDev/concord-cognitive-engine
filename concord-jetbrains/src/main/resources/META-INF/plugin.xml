<idea-plugin>
  <id>ai.concord.jetbrains</id>
  <name>Concord DX</name>
  <vendor email="hello@concord-os.org" url="https://concord-os.org">Concord OS</vendor>

  <description><![CDATA[
    Concord DX in JetBrains IDEs (IntelliJ IDEA, WebStorm, PyCharm, GoLand, etc.).<br/>
    Detector findings stream as inline highlights; repair-cortex proposals
    appear as Accept / Ignore / Reject prompts. Backed by the same
    <a href="https://github.com/ryttps94jq-gif/concord-cognitive-engine/tree/main/concord-lsp">concord-lsp</a>
    that powers the VS Code extension.
  ]]></description>

  <depends>com.intellij.modules.platform</depends>
  <depends>com.redhat.devtools.lsp4ij</depends>

  <extensions defaultExtensionNs="com.intellij">
    <!-- Persistent application-level settings -->
    <applicationService
      serviceImplementation="ai.concord.jetbrains.settings.ConcordSettingsState"/>

    <!-- Settings → Tools → Concord -->
    <applicationConfigurable
      parentId="tools"
      instance="ai.concord.jetbrains.settings.ConcordSettingsConfigurable"
      id="ai.concord.jetbrains.settings.ConcordSettingsConfigurable"
      displayName="Concord"/>

    <!-- View → Tool Windows → Concord -->
    <toolWindow
      id="Concord"
      anchor="right"
      icon="AllIcons.Actions.Find"
      factoryClass="ai.concord.jetbrains.toolwindow.ConcordToolWindowFactory"/>

    <!-- LSP server registration via LSP4IJ. The actual server.js binary
         is bundled with the plugin; LSP4IJ launches it via stdio. The
         LSP definition is registered programmatically in a follow-up
         commit so we can read the apiUrl + token from PasswordSafe at
         server-start time. -->
  </extensions>

  <actions>
    <action
      id="ai.concord.jetbrains.SignIn"
      class="ai.concord.jetbrains.actions.ConcordSignInAction"
      text="Concord: Sign in"
      description="Sign in to Concord via browser-based OAuth (RFC 8252 loopback redirect).">
      <add-to-group group-id="ToolsMenu" anchor="last"/>
    </action>
  </actions>

  <applicationListeners>
    <!-- Future: project-open listener wires the LSP startup hook once
         lsp4ij integration lands in v0.3. -->
  </applicationListeners>
</idea-plugin>
