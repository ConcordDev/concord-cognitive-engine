# Concord — RunPod Environment
# Fill in the values marked REQUIRED, then: cp .env.runpod .env

# ── REQUIRED ──────────────────────────────────────────────────────────────────

# Generate: openssl rand -hex 64
JWT_SECRET=

# Generate: openssl rand -hex 32
SESSION_SECRET=

# Your RunPod public URL (find in RunPod pod page → Connect → HTTP Service)
# Example: https://abc123def456-5050.proxy.runpod.net
RUNPOD_PUBLIC_URL=

# ── CLOUDFLARE TUNNEL (optional) ──────────────────────────────────────────────
# If you front the pod with a Cloudflare tunnel (or any reverse proxy) on a
# custom domain, set this to that domain. When set, startup.sh derives the
# public-facing vars below from it INSTEAD of RUNPOD_PUBLIC_URL — otherwise
# the frontend bundle bakes in the *.proxy.runpod.net URL, CORS rejects the
# tunnel origin, and auth cookies won't stick. Run: ./startup.sh --cloudflare
# Example: https://concord-os.org
TUNNEL_PUBLIC_URL=https://concord-os.org

# ── CLOUDFLARE TUNNEL TOKEN — eliminates tunnel SPOF ─────────────────────────
# When set, startup.sh launches cloudflared as a PM2-supervised process and
# the health-check watchdog (cron, every 5min) auto-restarts it on crash.
# Cloudflare natively multiplexes multiple connectors to the same tunnel, so
# running startup.sh on a second machine adds a hot-standby edge connector with
# zero extra config — tunnel stays up if either connector crashes.
#
# Get your token: Cloudflare Zero Trust → Tunnels → your tunnel → Configure → Token
# CLOUDFLARE_TUNNEL_TOKEN=

# ── SYSTEM LIMITS — critical for 10k+ concurrent connections ─────────────────
# startup.sh raises `ulimit -n 1048576` before PM2 starts (Linux default: 1024
# → crashes at ~200 concurrent users; 1M supports 200k+ connections).
# docker-compose sets this via `ulimits: nofile: 1048576` in all services.

# ── DATA DURABILITY — DB + backups MUST live on the network volume ───────────
# RunPod network volumes are PERSISTENT (survive pod reclaim/restart); the
# container disk is EPHEMERAL (wiped on reclaim). The SQLite DB is your entire
# data layer — put it on the volume or you WILL lose everything on a reclaim.
# RunPod mounts the network volume at /workspace by default — adjust if yours
# differs. These paths flow into startup.sh + scripts/db-backup.sh.
DATA_DIR=/workspace/concord
DB_PATH=/workspace/concord/db/concord.db
STATE_PATH=/workspace/concord/concord_state.json
# 6-hourly WAL-safe backups land here (also on the volume). startup.sh installs
# the cron + takes an initial snapshot.
CONCORD_BACKUP_DIR=/workspace/concord/backups
CONCORD_BACKUP_RETAIN=28
# OPTIONAL off-box copy (closes the "volume itself dies" gap). Set to an rclone
# remote ("r2:concord-backups") or an s3:// URL (needs aws-cli). Configure
# rclone first: rclone config. Leave blank to keep backups volume-local only.
# CONCORD_BACKUP_REMOTE=

# ── Public-facing origin — concord-os.org via the Cloudflare tunnel (same-origin) ─
# The tunnel serves the UI + proxies /api,/socket.io on ONE host, so all of these are
# the apex domain. (startup.sh --cloudflare would derive these from TUNNEL_PUBLIC_URL;
# set explicitly so they're correct even without it.)
FRONTEND_URL=https://concord-os.org
NEXT_PUBLIC_FRONTEND_URL=https://concord-os.org
ALLOWED_ORIGINS=https://concord-os.org,https://www.concord-os.org
NEXT_PUBLIC_API_URL=https://concord-os.org
NEXT_PUBLIC_SOCKET_URL=https://concord-os.org
COOKIE_DOMAIN=.concord-os.org

# ── OLLAMA — multi-instance, one per brain role (RunPod single pod, NO docker) ─
# Each brain runs as its OWN Ollama instance on its own port, CPU-core-pinned and
# GPU-assigned, serving its own model. Launch them with:  bash scripts/runpod-cognition.sh
# (it taskset-pins cores + sets CUDA_VISIBLE_DEVICES per role, pulls each model, and
# verifies the wiring). These URLs MUST match the ports that script binds.
OLLAMA_HOST=http://127.0.0.1:11434
BRAIN_CONSCIOUS_URL=http://127.0.0.1:11434
BRAIN_SUBCONSCIOUS_URL=http://127.0.0.1:11435
BRAIN_UTILITY_URL=http://127.0.0.1:11436
BRAIN_REPAIR_URL=http://127.0.0.1:11437
BRAIN_VISION_URL=http://127.0.0.1:11438

# ── CPU bands (auto-allocated from real `nproc` by runpod-cognition.sh) ──────────
# THREE tiers — inference is GPU-bound, so the brains get the SMALL band and Concordia
# gets the big one:
#   • brains (5 Ollama instances)         ~ OLLAMA_CORE_PCT (35%), low cores, split per role
#   • Concordia / world sim (the BACKEND: world-shard worker_threads + governorTick +
#     124 heartbeats + NPC/physics)        ~ the large MIDDLE band → its "power cores"
#   • frontend                            ~ FRONTEND_CORE_PCT (10%), top cores
# The launcher prints + exports CONCORD_WORLD_CORES; pin pid bands after start with:
#   CONCORD_WORLD_CORES=<range> bash scripts/pin-processes.sh
OLLAMA_CORE_PCT=35
FRONTEND_CORE_PCT=10
# Override a brain's cores only to take manual control of the auto split:
# NOTE: cores are AUTO-DETECTED from the pod's cgroup cpuset (/proc/self/status
# Cpus_allowed_list), NOT nproc — on RunPod nproc lies (reports the host's 100+ cores,
# not your slice). The launcher pins only within the allowed set. Override per-brain only
# if you know your exact allowed ids:
# BRAIN_CONSCIOUS_CORES=0-7
# BRAIN_SUBCONSCIOUS_CORES=8-11
# BRAIN_UTILITY_CORES=12-13
# BRAIN_REPAIR_CORES=14
# BRAIN_VISION_CORES=15
#
# SINGLE GPU (the 32GB Blackwell RTX Concord was tuned for): all brains share GPU 0.
# VRAM is the budget, not GPU count — the five models co-reside on the one card.
# Concordia's GPU "slice" (CONCORD_WORLD_VRAM_MB) is FIT MARGIN, not a hard fence:
# runpod-cognition.sh asks each instance to keep it free via OLLAMA_GPU_OVERHEAD, BUT that
# env var is NOT reliably enforced (ollama#12223) and Concordia has no server-side CUDA
# anyway (its 3D render is client-side Three.js). The real protections are (a) the pre-boot
# fit check (verify-resource-allocation.mjs) and (b) BRAIN_VISION_KEEP_ALIVE to shed ~6.9GB
# on demand. NOTE: with 5 SEPARATE serve processes there's no cross-process LRU — an
# over-commit is a hard CUDA OOM, not a graceful unload, so keep the fit honest + margin
# real. Concordia's DEDICATED cognition is the subconscious brain (dream/oracle/forward-sim).
#
# Sized for a 14B conscious flagship: the 5 brains resident ≈ 26 GB (14B≈9.6 + 7b≈5.3 +
# 3b≈2.9 + 0.5b≈1.3 + 7b-vl≈6.9), so a 4 GB slice + 1 GB system = ~31 GB, fits with
# ~1.6 GB margin and ALL brains stay hot. Want a bigger slice? either set vision to
# load-on-demand (BRAIN_VISION_KEEP_ALIVE=30s — it's bursty) or use a lighter conscious
# quant (q4_K_S). Verify before boot: node server/scripts/verify-resource-allocation.mjs
CONCORD_CONSCIOUS_PARAMS_B=14   # tells the verifier the custom concord-conscious size
CONCORD_WORLD_VRAM_MB=4096
CONCORD_WORLD_GPU=0
# CONCORD_GPU_PROFILE=32gb   # 12gb|16gb|24gb|32gb|cpu — scales models + concurrency down
BRAIN_CONSCIOUS_GPU=0
BRAIN_SUBCONSCIOUS_GPU=0
BRAIN_UTILITY_GPU=0
BRAIN_REPAIR_GPU=0
BRAIN_VISION_GPU=0
# Blackwell perf (per CLAUDE.md): tensor cores + halved KV cache, models stay resident.
OLLAMA_FLASH_ATTENTION=1
OLLAMA_KV_CACHE_TYPE=q8_0
OLLAMA_KEEP_ALIVE=30m
# NUM_PARALLEL=1 is load-bearing for the VRAM fit — KV cache scales with NUM_PARALLEL ×
# context, and there's no cross-process LRU across the 5 serve processes, so >1 risks a
# hard CUDA OOM. Raise only after measuring headroom with nvidia-smi under live load.
OLLAMA_NUM_PARALLEL=1
# Flash attention is EXPERIMENTAL on vision/multimodal (can degrade qwen2.5vl); the
# launcher defaults it OFF for the vision instance (which then uses f16 KV, since q8_0 KV
# requires flash attention). Override: BRAIN_VISION_FLASH_ATTENTION=1 to force it on.
# BRAIN_VISION_FLASH_ATTENTION=0
#
# EGRESS NOTE — if registry.ollama.ai is blocked on the pod (pull stalls/404s), the base
# models still have working paths (the custom concord-conscious build is 100% LOCAL once
# its qwen2.5:14b base exists). Ranked: (1) put a pre-pulled ~/.ollama/models blob store on
# the /workspace volume; (2) `ollama run hf.co/Qwen/Qwen2.5-7B-Instruct-GGUF:Q4_K_M` (pulls
# from Hugging Face, not the Ollama registry); (3) copy a .gguf in + `FROM /path.gguf` in a
# Modelfile. The minimal Ollama-registry allowlist is registry.ollama.ai + *.r2.cloudflarestorage.com.
# Per-role residency override (empty inherits OLLAMA_KEEP_ALIVE above). Uncomment to make
# the bursty vision brain (~6.9GB) load-on-demand and evict when idle — frees VRAM so you
# can raise CONCORD_WORLD_VRAM_MB (Concordia's slice) without over-committing the card.
# The cost: a cold-load latency on the first vision call after idle. Keep conscious +
# subconscious hot (they're on the chat + world-sim hot path) — only flip the bursty ones.
# BRAIN_VISION_KEEP_ALIVE=30s
# embeddings (small, CPU) — the substrate uses this for retrieval.
CONCORD_EMBED_OLLAMA_URL=http://127.0.0.1:11434

# ── Phase D — multi-endpoint scale-out (optional on RunPod) ──────────────────
# If you spin up a second Ollama process on the same pod (different port —
# e.g. OLLAMA_HOST=0.0.0.0:11435 ollama serve &) you can list both endpoints
# here and the brain router will round-robin across them, preferring the
# less-loaded endpoint per call. Leave blank to use the singular URL above.
# Example: http://localhost:11434,http://localhost:11435
# BRAIN_CONSCIOUS_URLS=
# BRAIN_SUBCONSCIOUS_URLS=
# BRAIN_UTILITY_URLS=
# BRAIN_REPAIR_URLS=
# BRAIN_VISION_URLS=

# Models — five-brain defaults from server/lib/brain-config.js, tuned for the
# RTX PRO 4500 Blackwell (32GB GDDR7). Pull commands:
#   # conscious is a custom model built from a Modelfile on top of qwen2.5
#   ollama pull qwen2.5:7b-instruct-q4_K_M     # subconscious
#   ollama pull qwen2.5:3b                     # utility
#   ollama pull qwen2.5:0.5b                   # repair
#   ollama pull qwen2.5vl:7b                   # vision/multimodal (Apache-2.0)
#   ollama pull nomic-embed-text               # semantic cache (~300MB VRAM)
BRAIN_CONSCIOUS_MODEL=concord-conscious:latest
BRAIN_SUBCONSCIOUS_MODEL=qwen2.5:7b-instruct-q4_K_M
BRAIN_UTILITY_MODEL=qwen2.5:3b
BRAIN_REPAIR_MODEL=qwen2.5:0.5b
BRAIN_VISION_MODEL=qwen2.5vl:7b
# ⚠️ MUTUALLY EXCLUSIVE with the OLLAMA_NUM_PARALLEL=1 set above. The default
# RunPod flow uses scripts/runpod-cognition.sh, which launches FIVE SEPARATE
# ollama processes and INHERITS this env var (`${OLLAMA_NUM_PARALLEL:-1}`) — so
# =16 here would push every one of the 5 processes to 16 parallel streams and
# hard-OOM the card. The active value therefore stays =1 (above). ONLY if you run
# a SINGLE shared Ollama instance instead (e.g. the docker-compose path, which
# actually sets per-service values itself), uncomment the line below AND comment
# the =1 above. Higher than 16 on one instance risks KV-cache thrash.
# OLLAMA_NUM_PARALLEL=16
OLLAMA_MAX_LOADED_MODELS=2
OLLAMA_NUM_THREAD=14

# Embeddings (for semantic cache — makes repeated queries instant)
# Pull with: ollama pull nomic-embed-text
EMBEDDING_MODEL=nomic-embed-text

# ── SERVER ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5050
TRUST_PROXY=1
AUTH_MODE=hybrid
AUTH_ENABLED=true

# ── Phase A — heartbeat dispatch tuning ──────────────────────────────────────
# Modules without `serial: true` run in parallel. MODULE_TIMEOUT_MS caps how
# long a single module can run before the dispatcher cancels it (Prom
# counter concord_heartbeat_module_timeout_total). Default 30s.
CONCORD_HEARTBEAT_MODULE_TIMEOUT_MS=30000

# ── Phase B — per-module timing history ──────────────────────────────────────
# How many samples per module to keep for /api/admin/heartbeat-stats. Memory
# cost ≈ 8 bytes × 60 × N_modules ≈ 33KB at default. Bump for longer p99 windows.
CONCORD_HEARTBEAT_TIMING_HISTORY=60

# ── Phase C — heartbeat worker pool ──────────────────────────────────────────
# Routes `worker: true` heartbeat modules off the main thread. RunPod pods
# typically have 28 vCPU; default is min(4, cpus-2) which gives 4 workers.
# Set to 0 to disable worker routing (modules still run inline). Each worker
# opens its own read-only better-sqlite3 handle.
CONCORD_HEARTBEAT_POOL_SIZE=4
CONCORD_HEARTBEAT_WORKER_TIMEOUT_MS=25000

# ── Phase F — process-per-world sharding (default OFF) ───────────────────────
# When CONCORD_SHARD_WORLDS=true the parent process forks one child per
# active world; per-world heartbeat modules (`scope: 'world'`) run inside
# the shard. The parent still owns HTTP, Socket.IO, and the writeable DB
# handle for user-global tables. Leave OFF until you've confirmed your
# RunPod pod has the CPU headroom (4+ vCPU per active world is a healthy
# baseline). Boot flag is read each tick, so toggling without restart works.
# Flipped ON: the Concordia "power core" band (CONCORD_WORLD_CORES, ~18 cores on a
# 32-core pod) is reserved for exactly these shard worker_threads; shards spawn
# on-demand + idle-tear-down, and the write-ownership protocol (world-shard-protocol.js
# PER_WORLD_WRITE_TABLES) prevents the write race. Toggle back to false per-tick if a
# burst of simultaneously-active worlds exceeds your headroom.
CONCORD_SHARD_WORLDS=true
CONCORD_SHARD_BACKOFF_MS=2000
CONCORD_SHARD_MAX_RESTARTS_PER_MIN=5

# ── TRANSACTIONAL EMAIL — REQUIRED for password reset + verification ─────────
# Without SMTP configured, the email service logs to console and NO email is
# sent — meaning a user who forgets their password is locked out permanently.
# nodemailer is bundled; just point it at any SMTP relay (SendGrid / AWS SES /
# Postmark / Mailgun all have free tiers). Example shown for SendGrid:
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_USER=apikey                 # SendGrid: literally the word "apikey"
#   SMTP_PASS=SG.xxxxxxxx            # your SendGrid API key
#   SMTP_FROM=noreply@concord-os.org # must be a verified sender/domain
#   SMTP_FROM_NAME=Concord
# (For AWS SES: SMTP_HOST=email-smtp.<region>.amazonaws.com, SMTP_USER/PASS =
#  SES SMTP credentials.) Verify after boot: GET /api/... email status, or
# check the boot log for "SMTP connected".
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@concord-os.org
SMTP_FROM_NAME=Concord

# ── OPTIONAL ─────────────────────────────────────────────────────────────────
# ADMIN_PASSWORD=
# ALERT_WEBHOOK_URL=https://hooks.slack.com/...   # error-alerting webhook (server-side)
# Backend error monitoring (Sentry). Set SENTRY_DSN to your project DSN and the
# server captures unhandled errors (PII-stripped: no user, no cookies). No-op
# when unset. Strongly recommended for launch — it's how you see prod crashes.
# SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>
# E5 — frontend error capture (Sentry). The SDK is already wired error-only with PII
# stripping (sentry.{client,server,edge}.config.js + next.config.js withSentryConfig).
# It stays dormant until BOTH are set at build time; setting them surfaces the
# white-screen / hydration class instantly. The build is byte-identical when unset.
# NEXT_PUBLIC_SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=          # only needed for source-map upload at build time

# E2 — economy-anomaly cycle is ON by default (observe-only). Disable with:
# CONCORD_ECON_ANOMALY=0

# ── FEATURE FLAGS — "all features on" prod manifest ──────────────────────────
# (Production Ship-Readiness spec §2.) The feature kill-switches default OFF in
# code; without these the default-OFF systems ship inert. Polarity per source.

# 2a. Default-OFF features → set to turn ON
CONCORD_CIVIC_BONDS=1
CONCORD_VIABILITY=1
CONCORD_VIABILITY_ETHICS=1
CONCORD_SOCIAL_LIFE=1
CONCORD_SOCIAL_EVENTS=1
CONCORD_SKILL_FORGE=1
CONCORD_CHILD_REFUSAL=1
CONCORD_AUTOFIX_LOOP=true          # gate is `!== "true"` → literal true (repair-cortex autonomous fix)
CONCORD_FIREARMS=1
CONCORD_EXPRESSION=1
CONCORD_REALM_CONTROL=1
CONCORD_MOVE_BUILDER=1
CONCORD_COUNCIL=1
# Killswitch-audit additions (default-OFF gameplay/sim systems that were dark in prod):
CONCORD_COLLAPSE_CASCADE=1
CONCORD_EVO_ASSET_GAMEPLAY=1
CONCORD_GOSSIP=1
CONCORD_WORLD_DENSITY=1
CONCORD_LIVING_CAREER=1
CONCORD_REPUTATION=1
CONCORD_FTUE_TELEMETRY=1

# 2b. LLM-gated features — prod HAS Ollama, so enable (each has a deterministic
# fallback, so this upgrades quality without risk). Requires #P1 dialogue-choice
# whitelist (shipped) before enabling NPC dialogue LLM.
CONCORD_SKILL_EVOLUTION_LLM=true
CONCORD_NPC_DIALOGUE_LLM=true
CONCORD_QUEST_DIALOGUE_LLM=true
CONCORD_DREAM_LLM=true
CONCORD_FORWARD_SIM_LLM=true
CONCORD_PROCGEN_BACKSTORY_LLM=true
CONCORD_FITNESS_PLAN_LLM=true

# 2b-Wave7. The autonomous-agent + awareness stack (built this cycle). These are the
# two FEATURE kill-switches that ship OFF-by-default (an agent shouldn't wake on a
# fresh deploy without the operator's say-so) — flipped ON for prod so the living
# layer actually runs: persistent agents (Caemira / the living-chat self), the
# salience brain-loop, autonomous goal formation, the awareness loop + reasoning
# journal, the initiative pulse, drift-watch. Guardrails stay enforced regardless
# (allowlist, Sparks-only, per-actor cap, disclosure, kill-switch). The rest of the
# Wave 7 switches (affect-salience, instinct, felt-trace, chat-awareness, chat-mood,
# initiative-cycle, autogoal, drift-watch, qualia-space, awareness-index) are already
# ON-by-default — listed here only for completeness/override.
CONCORD_AGENT_ENABLED=1
CONCORD_AWARENESS_LOOP=1
GPU_ENABLED=true
CONCORD_SPEED_AOI=true
# already on-by-default (set =0 to disable any): CONCORD_AFFECT_SALIENCE
# CONCORD_AFFECT_INSTINCT CONCORD_AFFECT_TRACE CONCORD_CHAT_AWARENESS
# CONCORD_CHAT_MOOD_PROMPT CONCORD_INITIATIVE_CYCLE CONCORD_AGENT_AUTOGOAL
# CONCORD_AGENT_DRIFT_WATCH CONCORD_QUALIA_SPACE CONCORD_AWARENESS_INDEX

# 2e. NEW this cycle — the Temperament engine (Phases 1–3: disposition gate +
# graded escalation ladder + two-meter authority). Off == today's archetype-only
# NPC behavior, byte-identical; ON activates emotional/social-state-driven
# hostility. Tested, kill-switched. (The spec called this a no-op — it's now real.)
CONCORD_TEMPERAMENT=1

# 2c. Observability — OpenTelemetry export (E5-adjacent). Gate is `=== "true"`.
# Off == no traces; on == spans export to CONCORD_OTEL_ENDPOINT. Safe in prod.
CONCORD_OTEL_ENABLED=true

# 2d. Security HARDENING — these default-OFF flags are protections, not features.
# Turning them ON is the secure posture for prod (their being off is itself a
# killswitch-audit finding):
CONCORD_ENFORCE_CSRF=true          # gate `!== "true"` → require CSRF tokens on writes
CONCORD_AP_REQUIRE_SIGNATURE=true  # gate `=== "true"` → reject unsigned ActivityPub federation

# ── Do NOT enable in prod ────────────────────────────────────────────────────
# Security RELAXATIONS (look like features, are holes — a blind "everything on"
# would open them; keep UNSET so the secure default holds):
#   CONCORD_WEBHOOK_ALLOW_OPEN       — opens unauthenticated webhooks
#   CONCORD_FEDERATION_ALLOW_LOOPBACK — relaxes federation loopback guard
# (CONCORD_SHARD_WORLDS is enabled ABOVE with rationale — the write-ownership protocol
#  in world-shard-protocol.js prevents the race; it's the Concordia power-core scale-out,
#  not a footgun. Toggle back to false per-tick if active-world count exceeds CPU headroom.)
# Infra / danger flags (operational footguns + the chaos fault-injector):
#   CONCORD_RATE_LIMIT_BYPASS
#   CONCORD_CHAOS_ENABLED · CONCORD_AP_DEBUG · CONCORD_DISABLE_CSRF
#   CONCORD_DISABLE_BRAINS · CONCORD_DISABLE_GHOST_FLEET · CONCORD_DISABLE_HEARTBEAT
