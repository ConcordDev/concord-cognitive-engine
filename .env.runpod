# Concord — RunPod Environment
# Fill in the values marked REQUIRED, then: cp .env.runpod .env

# ── REQUIRED ──────────────────────────────────────────────────────────────────

# Generate: openssl rand -hex 64
JWT_SECRET=

# Generate: openssl rand -hex 32
SESSION_SECRET=

# Your RunPod public URL (find in RunPod pod page → Connect → HTTP Service)
# Example: https://abc123def456-5050.proxy.runpod.net
RUNPOD_PUBLIC_URL=

# ── CLOUDFLARE TUNNEL (optional) ──────────────────────────────────────────────
# If you front the pod with a Cloudflare tunnel (or any reverse proxy) on a
# custom domain, set this to that domain. When set, startup.sh derives the
# public-facing vars below from it INSTEAD of RUNPOD_PUBLIC_URL — otherwise
# the frontend bundle bakes in the *.proxy.runpod.net URL, CORS rejects the
# tunnel origin, and auth cookies won't stick. Run: ./startup.sh --cloudflare
# Example: https://concord-os.org
TUNNEL_PUBLIC_URL=

# ── AUTO-SET FROM TUNNEL_PUBLIC_URL or RUNPOD_PUBLIC_URL ─────────────────────
# Leave blank and startup.sh fills these; set explicitly to override.
ALLOWED_ORIGINS=
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_SOCKET_URL=
COOKIE_DOMAIN=

# ── OLLAMA (RunPod: single Ollama instance, always localhost) ─────────────────
# All five brain slots point at the one on-pod Ollama; the model per slot is
# what differentiates them. (In docker-compose each brain gets its own
# container on 11434-11438; on a single RunPod pod they share one.)
OLLAMA_HOST=http://localhost:11434
BRAIN_CONSCIOUS_URL=http://localhost:11434
BRAIN_SUBCONSCIOUS_URL=http://localhost:11434
BRAIN_UTILITY_URL=http://localhost:11434
BRAIN_REPAIR_URL=http://localhost:11434
BRAIN_VISION_URL=http://localhost:11434

# ── Phase D — multi-endpoint scale-out (optional on RunPod) ──────────────────
# If you spin up a second Ollama process on the same pod (different port —
# e.g. OLLAMA_HOST=0.0.0.0:11435 ollama serve &) you can list both endpoints
# here and the brain router will round-robin across them, preferring the
# less-loaded endpoint per call. Leave blank to use the singular URL above.
# Example: http://localhost:11434,http://localhost:11435
# BRAIN_CONSCIOUS_URLS=
# BRAIN_SUBCONSCIOUS_URLS=
# BRAIN_UTILITY_URLS=
# BRAIN_REPAIR_URLS=
# BRAIN_VISION_URLS=

# Models — five-brain defaults from server/lib/brain-config.js, tuned for the
# RTX PRO 4500 Blackwell (32GB GDDR7). Pull commands:
#   # conscious is a custom model built from a Modelfile on top of qwen2.5
#   ollama pull qwen2.5:7b-instruct-q4_K_M     # subconscious
#   ollama pull qwen2.5:3b                     # utility
#   ollama pull qwen2.5:0.5b                   # repair
#   ollama pull qwen2.5vl:7b                   # vision/multimodal (Apache-2.0)
#   ollama pull nomic-embed-text               # semantic cache (~300MB VRAM)
BRAIN_CONSCIOUS_MODEL=concord-conscious:latest
BRAIN_SUBCONSCIOUS_MODEL=qwen2.5:7b-instruct-q4_K_M
BRAIN_UTILITY_MODEL=qwen2.5:3b
BRAIN_REPAIR_MODEL=qwen2.5:0.5b
BRAIN_VISION_MODEL=qwen2.5vl:7b
# Phase D — bumped 8 → 16 for the single-Ollama RunPod deploy. 16 concurrent
# inference streams across all loaded models. Anything higher than 16 on a
# single Ollama instance risks KV-cache thrash with the 5-brain model set.
OLLAMA_NUM_PARALLEL=16
OLLAMA_MAX_LOADED_MODELS=2
OLLAMA_NUM_THREAD=14

# Embeddings (for semantic cache — makes repeated queries instant)
# Pull with: ollama pull nomic-embed-text
EMBEDDING_MODEL=nomic-embed-text

# ── SERVER ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5050
TRUST_PROXY=1
AUTH_MODE=hybrid
AUTH_ENABLED=true

# ── Phase A — heartbeat dispatch tuning ──────────────────────────────────────
# Modules without `serial: true` run in parallel. MODULE_TIMEOUT_MS caps how
# long a single module can run before the dispatcher cancels it (Prom
# counter concord_heartbeat_module_timeout_total). Default 30s.
CONCORD_HEARTBEAT_MODULE_TIMEOUT_MS=30000

# ── Phase B — per-module timing history ──────────────────────────────────────
# How many samples per module to keep for /api/admin/heartbeat-stats. Memory
# cost ≈ 8 bytes × 60 × N_modules ≈ 33KB at default. Bump for longer p99 windows.
CONCORD_HEARTBEAT_TIMING_HISTORY=60

# ── Phase C — heartbeat worker pool ──────────────────────────────────────────
# Routes `worker: true` heartbeat modules off the main thread. RunPod pods
# typically have 28 vCPU; default is min(4, cpus-2) which gives 4 workers.
# Set to 0 to disable worker routing (modules still run inline). Each worker
# opens its own read-only better-sqlite3 handle.
CONCORD_HEARTBEAT_POOL_SIZE=4
CONCORD_HEARTBEAT_WORKER_TIMEOUT_MS=25000

# ── Phase F — process-per-world sharding (default OFF) ───────────────────────
# When CONCORD_SHARD_WORLDS=true the parent process forks one child per
# active world; per-world heartbeat modules (`scope: 'world'`) run inside
# the shard. The parent still owns HTTP, Socket.IO, and the writeable DB
# handle for user-global tables. Leave OFF until you've confirmed your
# RunPod pod has the CPU headroom (4+ vCPU per active world is a healthy
# baseline). Boot flag is read each tick, so toggling without restart works.
CONCORD_SHARD_WORLDS=false
CONCORD_SHARD_BACKOFF_MS=2000
CONCORD_SHARD_MAX_RESTARTS_PER_MIN=5

# ── OPTIONAL ─────────────────────────────────────────────────────────────────
# ADMIN_PASSWORD=
# ALERT_WEBHOOK_URL=https://hooks.slack.com/...
# SENTRY_DSN=

# ── FEATURE FLAGS — "all features on" prod manifest ──────────────────────────
# (Production Ship-Readiness spec §2.) The feature kill-switches default OFF in
# code; without these the default-OFF systems ship inert. Polarity per source.

# 2a. Default-OFF features → set to turn ON
CONCORD_CIVIC_BONDS=1
CONCORD_VIABILITY=1
CONCORD_VIABILITY_ETHICS=1
CONCORD_SOCIAL_LIFE=1
CONCORD_SOCIAL_EVENTS=1
CONCORD_SKILL_FORGE=1
CONCORD_CHILD_REFUSAL=1
CONCORD_AUTOFIX_LOOP=true          # gate is `!== "true"` → literal true
CONCORD_FIREARMS=1
CONCORD_EXPRESSION=1
CONCORD_REALM_CONTROL=1
CONCORD_MOVE_BUILDER=1
CONCORD_COUNCIL=1

# 2b. LLM-gated features — prod HAS Ollama, so enable (each has a deterministic
# fallback, so this upgrades quality without risk). Requires #P1 dialogue-choice
# whitelist (shipped) before enabling NPC dialogue LLM.
CONCORD_SKILL_EVOLUTION_LLM=true
CONCORD_NPC_DIALOGUE_LLM=true
CONCORD_QUEST_DIALOGUE_LLM=true
CONCORD_DREAM_LLM=true
CONCORD_FORWARD_SIM_LLM=true
CONCORD_PROCGEN_BACKSTORY_LLM=true

# 2e. NEW this cycle — the Temperament engine (Phases 1–3: disposition gate +
# graded escalation ladder + two-meter authority). Off == today's archetype-only
# NPC behavior, byte-identical; ON activates emotional/social-state-driven
# hostility. Tested, kill-switched. (The spec called this a no-op — it's now real.)
CONCORD_TEMPERAMENT=1

# Do NOT enable in prod: CONCORD_SHARD_WORLDS (single-process write race),
# CONCORD_RATE_LIMIT_BYPASS / CONCORD_DISABLE_* (debug only).
